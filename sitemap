// Matikan error reporting di layar agar tidak merusak struktur output jika ada peringatan server
error_reporting(0);
date_default_timezone_set('UTC');

$message = '';
$messageType = '';
$pingStatus = '';
$selfDestruct = false;

function getBaseUrl() {
    $protocol = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off' || $_SERVER['SERVER_PORT'] == 443) ? "https://" : "http://";
    $domainName = $_SERVER['HTTP_HOST'];
    return $protocol . $domainName;
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $urls_input = $_POST['urls'] ?? '';
    $filename = $_POST['filename'] ?? 'sitemap.xml';
    
    $raw_urls = array_filter(array_map('trim', explode("\n", $urls_input)));
    $processed_urls = [];
    $baseUrl = rtrim(getBaseUrl(), '/');

    if (empty($raw_urls)) {
        $message = "Harap masukkan minimal 1 URL atau path target.";
        $messageType = "error";
    } else {
        foreach ($raw_urls as $u) {
            // Bersihkan input dari karakter aneh yang bisa merusak XML
            $u = filter_var($u, FILTER_SANITIZE_URL);
            if (!preg_match("~^(?:f|ht)tps?://~i", $u)) {
                $u = $baseUrl . '/' . ltrim($u, '/');
            }
            if (filter_var($u, FILTER_VALIDATE_URL)) {
                $processed_urls[] = $u;
            }
        }

        if (empty($processed_urls)) {
            $message = "Format URL tidak valid. Pastikan input benar.";
            $messageType = "error";
        } else {
            try {
                // Inisialisasi DOMDocument dengan Strict Mode
                $dom = new DOMDocument('1.0', 'UTF-8');
                $dom->preserveWhiteSpace = false;
                $dom->formatOutput = true;

                $urlset = $dom->createElement('urlset');
                $urlset->setAttribute('xmlns', 'http://www.sitemaps.org/schemas/sitemap/0.9');
                $urlset->setAttribute('xmlns:xsi', 'http://www.w3.org/2001/XMLSchema-instance');
                $urlset->setAttribute('xsi:schemaLocation', 'http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd');
                $dom->appendChild($urlset);

                $currentDate = date('c');

                foreach ($processed_urls as $url) {
                    $urlNode = $dom->createElement('url');
                    
                    // htmlspecialchars dengan flag ENT_QUOTES | ENT_XML1 sangat krusial agar tidak ada tag HTML yang bocor
                    $locNode = $dom->createElement('loc', htmlspecialchars($url, ENT_QUOTES | ENT_XML1, 'UTF-8'));
                    $urlNode->appendChild($locNode);
                    
                    $lastmodNode = $dom->createElement('lastmod', $currentDate);
                    $urlNode->appendChild($lastmodNode);
                    
                    $changefreqNode = $dom->createElement('changefreq', 'hourly');
                    $urlNode->appendChild($changefreqNode);
                    
                    $priorityNode = $dom->createElement('priority', '1.00');
                    $urlNode->appendChild($priorityNode);
                    
                    $urlset->appendChild($urlNode);
                }

                $rootPath = $_SERVER['DOCUMENT_ROOT'] . '/' . ltrim($filename, '/');
                $xmlOutput = $dom->saveXML();
                
                // Hapus whitespace yang tidak sengaja terbawa di awal/akhir dokumen
                $xmlOutput = trim($xmlOutput);

                $result = @file_put_contents($rootPath, $xmlOutput);

                if ($result !== false) {
                    $sitemapUrl = $baseUrl . '/' . ltrim($filename, '/');
                    $message = "Sitemap berhasil di-generate. File fisik XML murni telah tercipta di root.";
                    $messageType = "success";

                    // Auto-Ping Google
                    $pingUrl = "https://www.google.com/ping?sitemap=" . urlencode($sitemapUrl);
                    $ch = curl_init($pingUrl);
                    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
                    curl_setopt($ch, CURLOPT_HEADER, true);
                    curl_setopt($ch, CURLOPT_TIMEOUT, 5);
                    $response = curl_exec($ch);
                    $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
                    curl_close($ch);

                    if ($httpCode == 200) {
                        $pingStatus = "Google Ping Sukses! Crawler diprioritaskan.";
                    } else {
                        $pingStatus = "Google Ping terkirim.";
                    }

                    $selfDestruct = true;

                } else {
                    $message = "Gagal menyimpan file. Cek permission folder (CHMOD 755/777).";
                    $messageType = "error";
                }
            } catch (Exception $e) {
                $message = "Engine Error: " . $e->getMessage();
                $messageType = "error";
            }
        }
    }
}
