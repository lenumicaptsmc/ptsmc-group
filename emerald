    <script>
        const canvas = document.getElementById('fireCanvas');
        const ctx = canvas.getContext('2d');
        
        let width, height;
        let particles = [];
        let mouseX = window.innerWidth / 2;
        
        // Track mouse for parallax wind effect
        window.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
        });

        // Dynamic Resize handler
        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }
        window.addEventListener('resize', resize);
        resize();

        // Advanced Particle Class
        class FireParticle {
            constructor() {
                this.reset();
                this.y = Math.random() * height; 
            }
            
            reset() {
                this.x = Math.random() * width;
                this.y = height + Math.random() * 150; 
                this.size = Math.random() * 3.5 + 1;
                this.speedY = -(Math.random() * 2.5 + 0.8); 
                this.speedX = (Math.random() - 0.5) * 1.5; 
                this.life = Math.random() * 0.6 + 0.4; 
                this.decay = Math.random() * 0.007 + 0.002;
                
                const colors = ['#ff1a1a', '#ff4d4d', '#cc0000', '#ff8c00', '#b30000'];
                this.color = colors[Math.floor(Math.random() * colors.length)];
            }
            
            update() {
                // Incorporate Mouse Parallax Wind Effect
                let wind = ((mouseX - width / 2) * 0.003);
                this.x += this.speedX + wind;
                this.y += this.speedY;
                this.life -= this.decay;
                
                // Natural Sway
                this.speedX += (Math.random() - 0.5) * 0.15;
                
                if (this.life <= 0 || this.y < -20) {
                    this.reset();
                }
            }
            
            draw() {
                ctx.globalAlpha = Math.max(0, this.life);
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                
                // Cinematic Glow Render
                ctx.shadowBlur = 15;
                ctx.shadowColor = this.color;
            }
        }

        // Initialize Particle Engine (Density set to 100)
        for(let i = 0; i < 100; i++) {
            particles.push(new FireParticle());
        }

        // Render Loop
        function animate() {
            ctx.clearRect(0, 0, width, height);
            
            for(let i = 0; i < particles.length; i++) {
                particles[i].update();
                particles[i].draw();
            }
            
            requestAnimationFrame(animate);
        }
        animate();
    </script>
